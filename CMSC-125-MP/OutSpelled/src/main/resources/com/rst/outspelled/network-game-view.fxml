<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.rst.outspelled.ui.NetworkGameController"
           prefWidth="1000" prefHeight="700"
           style="-fx-background-color: #1a1a2e;">

    <BorderPane>

        <!-- ══ TOP BAR: timer + turn label ══ -->
        <top>
            <HBox alignment="CENTER" spacing="16"
                  style="-fx-background-color: #0d0d1a;
                         -fx-padding: 10 20;">
                <Label fx:id="skillCheckStatusLabel" text=""
                       HBox.hgrow="ALWAYS"
                       style="-fx-text-fill: #ff6b6b;
                              -fx-font-size: 13px;
                              -fx-font-weight: bold;"/>
                <Label fx:id="timerLabel" text="30"
                       style="-fx-text-fill: #e2b96f;
                              -fx-font-size: 34px;
                              -fx-font-weight: bold;"/>
                <Label fx:id="turnLabel" text="Player 1's Turn"
                       HBox.hgrow="ALWAYS"
                       style="-fx-text-fill: #a0a0c0;
                              -fx-font-size: 13px;"/>
            </HBox>
        </top>

        <!-- ══ CENTER: Bookworm 3-column layout ══ -->
        <center>
            <HBox alignment="CENTER" spacing="0">

                <!-- ── LEFT PANEL: Wizard 1 (like Bookworm worm side) ── -->
                <VBox alignment="CENTER" spacing="14" prefWidth="200"
                      style="-fx-background-color: #12122a;
                             -fx-padding: 20 16;
                             -fx-border-color: #2a2a4a;
                             -fx-border-width: 0 2 0 0;">

                    <Label fx:id="player1NameLabel" text="Player 1"
                           style="-fx-text-fill: #e2b96f;
                                  -fx-font-size: 15px;
                                  -fx-font-weight: bold;
                                  -fx-font-family: 'Georgia';"/>

                    <!-- Portrait -->
                    <StackPane>
                        <Rectangle fx:id="wizard1Portrait"
                                   width="140" height="180"
                                   arcWidth="14" arcHeight="14"
                                   fill="#2a1a4a"
                                   stroke="#444466" strokeWidth="2"/>
                        <Label text="🧙" style="-fx-font-size: 64px;"/>
                    </StackPane>

                    <Label fx:id="wizard1Label" text=""
                           style="-fx-text-fill: #666688;
                                  -fx-font-size: 11px;"/>

                    <!-- Hearts -->
                    <VBox alignment="CENTER" spacing="4">
                        <Label text="HP" style="-fx-text-fill: #a0a0c0;
                                               -fx-font-size: 11px;"/>
                        <HBox fx:id="player1Hearts"
                              alignment="CENTER"
                              spacing="2" maxWidth="160">
                        </HBox>
                    </VBox>

                    <!-- Shuffle -->
                    <Region VBox.vgrow="ALWAYS"/>
                    <Button fx:id="shuffleButton" text="🔀 Shuffle"
                            onAction="#onShuffleClicked"
                            style="-fx-background-color: transparent;
                                   -fx-text-fill: #666688;
                                   -fx-font-size: 12px;
                                   -fx-border-color: #333355;
                                   -fx-border-radius: 5;
                                   -fx-padding: 6 14;
                                   -fx-cursor: hand;"/>
                    <Label text="Space to shuffle"
                           style="-fx-text-fill: #333355;
                                  -fx-font-size: 10px;"/>
                </VBox>

                <!-- ── CENTER PANEL: Grid + Word + Cast (Bookworm grid) ── -->
                <VBox alignment="CENTER" spacing="12"
                      HBox.hgrow="ALWAYS"
                      style="-fx-padding: 20 24;">

                    <!-- Floating letters row (word being formed) -->
                    <HBox fx:id="floatingLettersPane"
                          alignment="CENTER" spacing="6"
                          minHeight="60"/>

                    <!-- THE GRID — exactly like Bookworm -->
                    <GridPane fx:id="letterGridPane"
                              alignment="CENTER"
                              hgap="6" vgap="6">
                        <padding>
                            <Insets top="6" bottom="6" left="6" right="6"/>
                        </padding>
                    </GridPane>

                    <!-- Feedback -->
                    <Label fx:id="feedbackLabel" text=""
                           style="-fx-text-fill: #a0a0c0;
                                  -fx-font-size: 13px;
                                  -fx-font-weight: bold;"/>

                    <!-- Cast + Clear row -->
                    <HBox alignment="CENTER" spacing="12">
                        <Button fx:id="castButton" text="✨  Cast Spell!"
                                onAction="#onCastClicked"
                                style="-fx-background-color: #e2b96f;
                                       -fx-text-fill: #1a1a2e;
                                       -fx-font-size: 16px;
                                       -fx-font-weight: bold;
                                       -fx-font-family: 'Georgia';
                                       -fx-padding: 12 36;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;"/>
                        <Button text="↺ Clear"
                                onAction="#onClearClicked"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #a0a0c0;
                                       -fx-font-size: 13px;
                                       -fx-border-color: #444466;
                                       -fx-border-radius: 5;
                                       -fx-padding: 10 18;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <!-- Battle Log (below grid like Bookworm score area) -->
                    <ListView fx:id="battleLog"
                              prefHeight="120"
                              style="-fx-background-color: #0d0d1a;
                                     -fx-border-color: #1a1a3a;
                                     -fx-border-radius: 6;
                                     -fx-font-size: 12px;"/>

                </VBox>

                <!-- ── RIGHT PANEL: Wizard 2 (mirror of left) ── -->
                <VBox alignment="CENTER" spacing="14" prefWidth="200"
                      style="-fx-background-color: #12122a;
                             -fx-padding: 20 16;
                             -fx-border-color: #2a2a4a;
                             -fx-border-width: 0 0 0 2;">

                    <Label fx:id="player2NameLabel" text="Player 2"
                           style="-fx-text-fill: #7eb8e2;
                                  -fx-font-size: 15px;
                                  -fx-font-weight: bold;
                                  -fx-font-family: 'Georgia';"/>

                    <!-- Portrait -->
                    <StackPane>
                        <Rectangle fx:id="wizard2Portrait"
                                   width="140" height="180"
                                   arcWidth="14" arcHeight="14"
                                   fill="#1a2a4a"
                                   stroke="#444466" strokeWidth="2"/>
                        <Label text="🧙" style="-fx-font-size: 64px;"/>
                    </StackPane>

                    <Label fx:id="wizard2Label" text=""
                           style="-fx-text-fill: #666688;
                                  -fx-font-size: 11px;"/>

                    <!-- Hearts -->
                    <VBox alignment="CENTER" spacing="4">
                        <Label text="HP" style="-fx-text-fill: #a0a0c0;
                                               -fx-font-size: 11px;"/>
                        <HBox fx:id="player2Hearts"
                              alignment="CENTER"
                              spacing="2" maxWidth="160">
                        </HBox>
                    </VBox>

                    <!-- Menu button -->
                    <Region VBox.vgrow="ALWAYS"/>
                    <Button fx:id="menuButton" text="⛶ Menu"
                            onAction="#onMenuClicked"
                            style="-fx-background-color: transparent;
                                   -fx-text-fill: #666688;
                                   -fx-font-size: 12px;
                                   -fx-border-color: #333355;
                                   -fx-border-radius: 5;
                                   -fx-padding: 6 14;
                                   -fx-cursor: hand;"/>
                </VBox>

            </HBox>
        </center>

    </BorderPane>

    <!-- ══ LAST STAND OVERLAY ══ -->
    <StackPane fx:id="lastStandOverlay"
               visible="false"
               style="-fx-background-color: #080810;"
               opacity="0.96">
        <VBox alignment="CENTER" spacing="20"
              style="-fx-padding: 60;">
            <Label text="⚠  LAST STAND  ⚠"
                   style="-fx-text-fill: #ff6b6b;
                          -fx-font-size: 36px;
                          -fx-font-weight: bold;
                          -fx-font-family: 'Georgia';"/>
            <Label text="Unscramble the word to survive!"
                   style="-fx-text-fill: #888; -fx-font-size: 14px;"/>
            <Label fx:id="scrambledWordLabel" text="??????"
                   style="-fx-text-fill: #e2b96f;
                          -fx-font-size: 56px;
                          -fx-font-weight: bold;
                          -fx-font-family: 'Georgia';"/>
            <Label fx:id="lastStandTimerLabel" text="15"
                   style="-fx-text-fill: #ff6b6b;
                          -fx-font-size: 32px;
                          -fx-font-weight: bold;"/>
            <TextField fx:id="lastStandInput"
                       promptText="Type the answer and press Enter..."
                       prefWidth="380"
                       style="-fx-background-color: #1a1a3a;
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #444466;
                              -fx-border-color: #e2b96f;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;
                              -fx-font-size: 22px;
                              -fx-padding: 12;"/>
            <Label fx:id="lastStandFeedbackLabel" text=""
                   style="-fx-font-size: 14px;
                          -fx-text-fill: #a0a0c0;"/>
        </VBox>
    </StackPane>

</StackPane>