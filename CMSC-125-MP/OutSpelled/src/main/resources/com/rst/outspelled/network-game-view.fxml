<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.rst.outspelled.ui.NetworkGameController"
           prefWidth="900" prefHeight="650">

    <BorderPane style="-fx-background-color: #1a1a2e;">
        <top>
            <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #12122a; -fx-padding: 12;">
                <VBox alignment="CENTER_LEFT" spacing="4" HBox.hgrow="ALWAYS">
                    <Label fx:id="player1NameLabel" text="Player 1" style="-fx-text-fill: #e2b96f; -fx-font-size: 14px;"/>
                    <HBox fx:id="player1Hearts" spacing="2" alignment="CENTER_LEFT"/>
                </VBox>
                <VBox alignment="CENTER" spacing="2" minWidth="100">
                    <Label fx:id="timerLabel" text="30" style="-fx-text-fill: #e2b96f; -fx-font-size: 30px; -fx-font-weight: bold;"/>
                    <Label fx:id="turnLabel" text="Player 1's Turn" style="-fx-text-fill: #a0a0c0; -fx-font-size: 10px;"/>
                </VBox>
                <VBox alignment="CENTER_RIGHT" spacing="4" HBox.hgrow="ALWAYS">
                    <Label fx:id="player2NameLabel" text="Player 2" style="-fx-text-fill: #7eb8e2; -fx-font-size: 14px;"/>
                    <HBox fx:id="player2Hearts" spacing="2" alignment="CENTER_RIGHT"/>
                </VBox>
            </HBox>
        </top>

        <center>
            <HBox alignment="CENTER" spacing="16" style="-fx-padding: 10;">
                <!-- Left: portrait + shuffle -->
                <VBox alignment="BOTTOM_CENTER" spacing="8" prefWidth="140">
                    <Rectangle fx:id="wizard1Portrait" width="100" height="130" arcWidth="10" arcHeight="10"
                               fill="#2a1a4a" stroke="#444466" strokeWidth="1.5"/>
                    <Label fx:id="wizard1Label" text="Wizard 1" style="-fx-text-fill: #e2b96f; -fx-font-size: 12px;"/>
                    <Button fx:id="shuffleButton" text="🔀 Shuffle (Space)" onAction="#onShuffleClicked"
                            style="-fx-background-color: transparent; -fx-text-fill: #a0a0c0; -fx-font-size: 12px;
                                   -fx-border-color: #a0a0c0; -fx-border-radius: 5; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </VBox>

                <!-- Center: floating letters + grid + cast -->
                <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
                    <Label fx:id="skillCheckStatusLabel" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <HBox fx:id="floatingLettersPane" alignment="CENTER" spacing="4" minHeight="52"/>
                    <GridPane fx:id="letterGridPane" alignment="CENTER" hgap="6" vgap="6">
                        <padding><Insets top="5" bottom="5" left="5" right="5"/></padding>
                    </GridPane>
                    <Label fx:id="feedbackLabel" text="" style="-fx-text-fill: #a0a0c0; -fx-font-size: 12px;"/>
                    <Button fx:id="castButton" text="✨ Cast!" onAction="#onCastClicked"
                            style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;
                                   -fx-padding: 12 40 12 40; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </VBox>

                <!-- Right: portrait + menu -->
                <VBox alignment="BOTTOM_CENTER" spacing="8" prefWidth="140">
                    <Rectangle fx:id="wizard2Portrait" width="100" height="130" arcWidth="10" arcHeight="10"
                               fill="#1a2a4a" stroke="#444466" strokeWidth="1.5"/>
                    <Label fx:id="wizard2Label" text="Wizard 2" style="-fx-text-fill: #7eb8e2; -fx-font-size: 12px;"/>
                    <Button fx:id="menuButton" text="Menu" onAction="#onMenuClicked"
                            style="-fx-background-color: transparent; -fx-text-fill: #a0a0c0; -fx-font-size: 12px;
                                   -fx-border-color: #a0a0c0; -fx-border-radius: 5; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </VBox>
            </HBox>
        </center>
    </BorderPane>

    <StackPane fx:id="lastStandOverlay" visible="false" style="-fx-background-color: #000000;" opacity="0.88">
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 40;">
            <Label text="⚠ LAST STAND ⚠" style="-fx-text-fill: #ff6b6b; -fx-font-size: 32px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
            <Label text="Unscramble the word to survive!" style="-fx-text-fill: #a0a0c0; -fx-font-size: 14px;"/>
            <Label fx:id="scrambledWordLabel" text="??????" style="-fx-text-fill: #e2b96f; -fx-font-size: 48px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
            <Label fx:id="lastStandTimerLabel" text="15" style="-fx-text-fill: #ff6b6b; -fx-font-size: 28px; -fx-font-weight: bold;"/>
            <TextField fx:id="lastStandInput" promptText="Type the unscrambled word..." prefWidth="320"
                       style="-fx-background-color: #2a2a4a; -fx-text-fill: white; -fx-prompt-text-fill: #666688; -fx-border-color: #e2b96f; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 20px; -fx-padding: 10;"/>
            <Label fx:id="lastStandFeedbackLabel" text="" style="-fx-font-size: 13px; -fx-text-fill: #a0a0c0;"/>
        </VBox>
    </StackPane>
</StackPane>
