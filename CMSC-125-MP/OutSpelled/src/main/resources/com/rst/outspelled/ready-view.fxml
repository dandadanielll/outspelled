<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rst.outspelled.ui.ReadyController"
      alignment="CENTER"
      spacing="24"
      style="-fx-background-color: #1a1a2e;"
      prefWidth="500"
      prefHeight="400">

    <padding>
        <Insets top="40" bottom="40" left="50" right="50"/>
    </padding>

    <Label text="Ready for the Mana Wheel?"
           style="-fx-font-size: 24px; -fx-font-weight: bold;
                  -fx-text-fill: #e2b96f; -fx-font-family: 'Georgia';"/>

    <Label text="Both players must confirm before the skill-check wheel starts."
           style="-fx-font-size: 13px; -fx-text-fill: #a0a0c0;"/>

    <HBox alignment="CENTER" spacing="60">
        <VBox alignment="CENTER" spacing="10">
            <Label fx:id="player1NameLabel" text="Player 1"
                   style="-fx-text-fill: #e2b96f; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Button fx:id="player1ReadyButton" text="Ready"
                    onAction="#onPlayer1ReadyClicked"
                    style="-fx-background-color: #2a2a4a;
                           -fx-text-fill: #e2b96f;
                           -fx-border-color: #e2b96f;
                           -fx-border-radius: 5;
                           -fx-padding: 10 24 10 24;
                           -fx-cursor: hand;"/>
            <Label fx:id="player1StatusLabel" text=""
                   style="-fx-text-fill: #4caf50; -fx-font-size: 12px;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="10">
            <Label fx:id="player2NameLabel" text="Player 2"
                   style="-fx-text-fill: #7eb8e2; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Button fx:id="player2ReadyButton" text="Ready"
                    onAction="#onPlayer2ReadyClicked"
                    style="-fx-background-color: #2a2a4a;
                           -fx-text-fill: #7eb8e2;
                           -fx-border-color: #7eb8e2;
                           -fx-border-radius: 5;
                           -fx-padding: 10 24 10 24;
                           -fx-cursor: hand;"/>
            <Label fx:id="player2StatusLabel" text=""
                   style="-fx-text-fill: #4caf50; -fx-font-size: 12px;"/>
        </VBox>
    </HBox>

    <Label fx:id="statusLabel" text=""
           style="-fx-text-fill: #a0a0c0; -fx-font-size: 13px;"/>

</VBox>
