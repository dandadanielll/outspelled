<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rst.outspelled.ui.LoginController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #1a1a2e;"
      prefWidth="500"
      prefHeight="520">

    <padding>
        <Insets top="40" bottom="40" left="60" right="60"/>
    </padding>

    <!-- Title -->
    <Label text="OutSpelled"
           style="-fx-font-size: 40px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #e2b96f;
                  -fx-font-family: 'Georgia';"/>
    <Label text="Enter the dueling arena"
           style="-fx-font-size: 13px; -fx-text-fill: #666688;"/>

    <!-- Tabs -->
    <TabPane fx:id="loginTabPane"
             tabClosingPolicy="UNAVAILABLE"
             style="-fx-background-color: #12122a;
                    -fx-border-color: #2a2a4a;
                    -fx-border-radius: 8;"
             VBox.vgrow="NEVER">

        <!-- Sign In Tab -->
        <Tab text="Sign In">
            <content>
                <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: #1a1a2e;">

                    <Label text="Username"
                           style="-fx-text-fill: #e2b96f; -fx-font-size: 12px;"/>
                    <TextField fx:id="signInUsername"
                               promptText="Enter username"
                               style="-fx-background-color: #2a2a4a;
                                      -fx-text-fill: white;
                                      -fx-prompt-text-fill: #555577;
                                      -fx-border-color: #444466;
                                      -fx-border-radius: 5;
                                      -fx-background-radius: 5;
                                      -fx-padding: 10;
                                      -fx-font-size: 14px;"/>

                    <Label text="Password"
                           style="-fx-text-fill: #e2b96f; -fx-font-size: 12px;"/>
                    <PasswordField fx:id="signInPassword"
                                   promptText="Enter password"
                                   style="-fx-background-color: #2a2a4a;
                                         -fx-text-fill: white;
                                         -fx-prompt-text-fill: #555577;
                                         -fx-border-color: #444466;
                                         -fx-border-radius: 5;
                                         -fx-background-radius: 5;
                                         -fx-padding: 10;
                                         -fx-font-size: 14px;"/>

                    <Button text="Sign In →"
                            onAction="#onSignInClicked"
                            style="-fx-background-color: #e2b96f;
                                   -fx-text-fill: #1a1a2e;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 14px;
                                   -fx-padding: 12 30;
                                   -fx-background-radius: 6;
                                   -fx-cursor: hand;"/>

                </VBox>
            </content>
        </Tab>

        <!-- Sign Up Tab -->
        <Tab text="Sign Up">
            <content>
                <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: #1a1a2e;">

                    <Label text="Username"
                           style="-fx-text-fill: #e2b96f; -fx-font-size: 12px;"/>
                    <TextField fx:id="signUpUsername"
                               promptText="Choose a username"
                               style="-fx-background-color: #2a2a4a;
                                      -fx-text-fill: white;
                                      -fx-prompt-text-fill: #555577;
                                      -fx-border-color: #444466;
                                      -fx-border-radius: 5;
                                      -fx-background-radius: 5;
                                      -fx-padding: 10;
                                      -fx-font-size: 14px;"/>

                    <Label text="Password"
                           style="-fx-text-fill: #e2b96f; -fx-font-size: 12px;"/>
                    <PasswordField fx:id="signUpPassword"
                                   promptText="Create a password"
                                   style="-fx-background-color: #2a2a4a;
                                         -fx-text-fill: white;
                                         -fx-prompt-text-fill: #555577;
                                         -fx-border-color: #444466;
                                         -fx-border-radius: 5;
                                         -fx-background-radius: 5;
                                         -fx-padding: 10;
                                         -fx-font-size: 14px;"/>

                    <Label text="Confirm Password"
                           style="-fx-text-fill: #e2b96f; -fx-font-size: 12px;"/>
                    <PasswordField fx:id="signUpConfirm"
                                   promptText="Confirm your password"
                                   style="-fx-background-color: #2a2a4a;
                                         -fx-text-fill: white;
                                         -fx-prompt-text-fill: #555577;
                                         -fx-border-color: #444466;
                                         -fx-border-radius: 5;
                                         -fx-background-radius: 5;
                                         -fx-padding: 10;
                                         -fx-font-size: 14px;"/>

                    <Button text="Create Wizard →"
                            onAction="#onSignUpClicked"
                            style="-fx-background-color: #4a7c59;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 14px;
                                   -fx-padding: 12 30;
                                   -fx-background-radius: 6;
                                   -fx-cursor: hand;"/>

                </VBox>
            </content>
        </Tab>

    </TabPane>

    <!-- Error label below tabs -->
    <Label fx:id="loginErrorLabel" text=""
           style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px;"/>

</VBox>