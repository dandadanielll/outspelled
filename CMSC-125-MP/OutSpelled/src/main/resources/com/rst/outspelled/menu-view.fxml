<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rst.outspelled.ui.MenuController"
      alignment="CENTER"
      spacing="24"
      style="-fx-background-color: #1a1a2e;"
      prefWidth="700"
      prefHeight="600">

    <padding><Insets top="50" bottom="50" left="60" right="60"/></padding>

    <!-- Title (wizard / Bookworm-style) -->
    <VBox alignment="CENTER" spacing="4">
        <Label text="OutSpelled"
               style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #e2b96f; -fx-font-family: 'Georgia';"/>
        <Label text="A Wizard Dueling Word Game"
               style="-fx-font-size: 16px; -fx-text-fill: #a0a0c0; -fx-font-family: 'Georgia';"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS" maxHeight="20"/>

    <!-- Menu buttons -->
    <VBox alignment="CENTER" spacing="12">
        <Button fx:id="startGameButton" text="⚡ Start Game"
                onAction="#onStartGameClicked"
                style="-fx-background-color: #e2b96f; -fx-text-fill: #1a1a2e; -fx-font-size: 18px; -fx-font-weight: bold;
                       -fx-padding: 14 40 14 40; -fx-background-radius: 8; -fx-cursor: hand; -fx-min-width: 220;"/>

        <Button fx:id="optionsButton" text="⚙ Options"
                onAction="#onOptionsClicked"
                style="-fx-background-color: transparent; -fx-text-fill: #a0a0c0; -fx-font-size: 14px;
                       -fx-border-color: #a0a0c0; -fx-border-radius: 6; -fx-padding: 10 28 10 28; -fx-cursor: hand; -fx-min-width: 220;"/>

        <Button fx:id="shopButton" text="🛒 Shop (Cosmetics)"
                onAction="#onShopClicked"
                style="-fx-background-color: transparent; -fx-text-fill: #a0a0c0; -fx-font-size: 14px;
                       -fx-border-color: #a0a0c0; -fx-border-radius: 6; -fx-padding: 10 28 10 28; -fx-cursor: hand; -fx-min-width: 220;"/>

        <Button fx:id="tutorialButton" text="📖 Tutorial"
                onAction="#onTutorialClicked"
                style="-fx-background-color: transparent; -fx-text-fill: #a0a0c0; -fx-font-size: 14px;
                       -fx-border-color: #a0a0c0; -fx-border-radius: 6; -fx-padding: 10 28 10 28; -fx-cursor: hand; -fx-min-width: 220;"/>

        <Button fx:id="quitButton" text="Quit"
                onAction="#onQuitClicked"
                style="-fx-background-color: transparent; -fx-text-fill: #8888aa; -fx-font-size: 13px;
                       -fx-border-color: #666688; -fx-border-radius: 6; -fx-padding: 8 24 8 24; -fx-cursor: hand; -fx-min-width: 220;"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS" maxHeight="20"/>

    <HBox alignment="CENTER" spacing="8" style="-fx-padding: 5;">
        <Label text="Window:" style="-fx-text-fill: #606080; -fx-font-size: 12px;"/>
        <ComboBox fx:id="windowModeCombo" maxWidth="160" style="-fx-background-color: #2a2a4a; -fx-text-fill: #e2b96f;"/>
    </HBox>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
</VBox>
